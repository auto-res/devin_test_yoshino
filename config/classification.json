{
    "optim": {
        "optimizer": {
            "name": "new_optimizer",
            "lr": 0.001,
            "beta1": 0.9,
            "beta2": 0.999,
            "epsilon": 1e-08,
            "betas_aggmo": [
                0.0,
                0.9,
                0.99
            ]
        },
        "lr_schedule": {
            "name": "step",
            "lr_decay": 0.1,
            "milestones": [
                150,
                250
            ],
            "last_epoch": -1
        },
        "epochs": 400,
        "batch_size": 128,
        "wdecay": 5e-4,
        "criterion": {
            "tag": "acc",
            "minmax": "max"
        }
    },
    "model": {
        "type": "resnet34"
    },
    "dataset": "cifar10"
}
