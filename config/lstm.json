{
    "model_type": "lstm",
    "dataset": "ptb",
    "batch_size": 80,
    "seq_length": 35,
    "epochs": 200,
    "seed": 42,
    "patience": 5,
    "model_config": {
        "embedding_dim": 650,
        "hidden_dim": 650,
        "num_layers": 2,
        "dropout": 0.5
    },
    "optimizers": {
        "adam": {
            "lr": 0.001,
            "beta1": 0.9,
            "beta2": 0.999,
            "epsilon": 1e-8
        },
        "aggmo": {
            "lr": 0.001,
            "betas": [0.0, 0.9, 0.99],
            "weight_decay": 0
        },
        "new_optimizer": {
            "lr": 0.001,
            "beta1": 0.9,
            "beta2": 0.999,
            "epsilon": 1e-8,
            "betas_aggmo": [0.0, 0.9, 0.99],
            "weight_decay": 0
        }
    }
}
